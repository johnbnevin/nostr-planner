{
  "name": "nostr-planner-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/planner",
    "build": "npm run build --workspace=apps/planner",
    "deploy": "npm run deploy --workspace=apps/planner",
    "dev:daemon": "npm run dev --workspace=apps/daemon",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nostrify/react": "^0.2.20"
  }
}
