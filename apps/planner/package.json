{
  "name": "@nostr-planner/app",
  "version": "1.11.0",
  "description": "A personal planner and calendar built on Nostr — no accounts, no servers, just your keys",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8000",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && nsite-cli deploy ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build"
  },
  "dependencies": {
    "@nostr-planner/ical-utils": "*",
    "@nostrify/nostrify": "0.50.5",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@types/qrcode": "^1.5.6",
    "blossom-client-sdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "nostr-tools": "^2.10.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.2"
  }
}
