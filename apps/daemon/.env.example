# ── Required ──────────────────────────────────────────────────────────
# Nostr private key for the daemon bot (nsec1... or 64-char hex).
# WARNING: This private key grants full signing ability for the bot account.
# Never commit to version control. Rotate immediately if exposed.
BOT_NSEC=nsec1...

# ── Web Push (for browser notifications) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# ── Optional tuning ──────────────────────────────────────────────────
# Max hours a user's push data can be stale before skipping (default: 36)
MAX_STALE_HOURS=36

# How often to check for pending push notifications (default: 60 seconds)
PUSH_CHECK_INTERVAL_SECS=60

# ── CalDAV iCal feed server (optional) ────────────────────────────────
# Set to a port number to serve public calendar events as iCal feeds.
# URL pattern: http://localhost:{port}/cal/{npub}.ics
# Set to 0 or leave empty to disable.
CALDAV_PORT=0

# Set to 1 if the daemon is behind a trusted reverse proxy (nginx, Caddy, etc.)
# that sets X-Forwarded-For. Improves rate limiting accuracy.
# WARNING: do NOT set this if the daemon is exposed directly to the internet.
TRUST_PROXY=0

# Comma-separated list of Nostr relay WebSocket URLs for the daemon to connect to.
# Defaults to damus + ditto if not set. Max 5 used. List the relay you'd like
# to treat as primary first.
# RELAYS=wss://relay.damus.io,wss://relay.ditto.pub
